---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { siteConfig } from '@/config';

const seoData = {
  title: `About | ${siteConfig.title}`,
  description: 'Learn more about Kathy Ko.',
};
---

<BaseLayout seoData={seoData}>
  <div class="py-12 relative">
    <div class="mx-auto px-4 sm:px-6 lg:px-8" style={`max-width: ${siteConfig.layout.contentWidth}`}>
      
      <h1 class="text-4xl font-black text-primary-900 dark:text-primary-50 mb-8 tracking-tight">
        About Me
      </h1>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">

        <div class="col-span-1 md:col-span-2 bg-yellow-50 dark:bg-yellow-900/20 rounded-3xl p-8 border-2 border-black dark:border-primary-700 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,0.2)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-200">
          <h2 class="text-2xl font-bold mb-6 text-black dark:text-white">
            Hello World, This is Kathy 👋
          </h2>
          
          <div class="space-y-4 text-lg leading-relaxed text-gray-700 dark:text-gray-200">
            <p>
              A postgraduate student at NUS from Taiwan. From Literature to AI, and from Taiwan to Singapore, this not-so-straightforward journey has been a mix of self-discovery, skepticism, and ambiguity.
            </p>
            <p>
              Early 20s feel like a run-on sentence. With so much to do and desire but never enough time. Trying hard and working hard but still feeling behind. Amidst the noise of individual pursuits, it inevitably feels lonely.
            </p>
            <p>
              Previous versions of portfolios existed solely to log technical skills, driven simply by a fear of failure and a need to prove competence. But she deep down believes that while science and engineering are noble pursuits and necessary to sustain life, art and the humanities are what we stay alive for.
            </p>
            <p>
              This website will no longer just be a technical record. It is a place to wear both failure and happiness as badges of honor. It is an attempt to slow down, feel, and document the various shapes of her 20s.
            </p>
          </div>
        </div>

        <div class="col-span-1 flex flex-col gap-6">
          
          <div class="relative h-64 rounded-3xl overflow-hidden border-2 border-black dark:border-primary-700 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,0.2)] group">
            <img 
              src="/profile.jpg" 
              alt="Kathy Ko" 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110 object-center"
              onerror="this.src='https://images.unsplash.com/photo-1544716278-ca5e3f4abd8c?q=80&w=1974&auto=format&fit=crop'" 
            />
          </div>

          <div class="bg-purple-50 dark:bg-purple-900/20 rounded-3xl p-6 border-2 border-black dark:border-primary-700 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,0.2)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-200 flex-1">
            <h3 class="text-xl font-bold mb-4 text-black dark:text-white flex items-center gap-2">
              🕹️ Interests
            </h3>
            <div class="flex flex-wrap gap-2">
              <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">📷 Photography</span>
              <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">🎧 Music</span>
              <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">✈️ Travel</span>
              <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">🤿 Scuba Diving</span>
              <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">🥊 Muay Thai</span>
            </div>
          </div>

        </div>

        <div class="col-span-1 flex flex-col gap-6">
          
          <div class="bg-blue-50 dark:bg-blue-900/20 rounded-3xl p-8 border-2 border-black dark:border-primary-700 shadow-[6px_6px_0px_0px_rgba(0,0,0,1)] dark:shadow-[6px_6px_0px_0px_rgba(255,255,255,0.2)] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all duration-200">
            <h3 class="text-xl font-bold mb-4 text-black dark:text-white flex items-center gap-2">
              🛠 Tech Stack
            </h3>
            
            <div class="space-y-4">
              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Core</span>
                <div class="flex flex-wrap gap-2 mt-1">
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Python</span>
                </div>
              </div>

              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">AI & Ops</span>
                <div class="flex flex-wrap gap-2 mt-1">
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">LangChain</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">LangGraph</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Google ADK</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Agent Orchestration</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">RAG</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Prompt Engineering</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Vector DB</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">GCP</span>
                </div>
              </div>

              <div>
                <span class="text-xs font-semibold text-gray-500 uppercase tracking-wider">Frameworks</span>
                <div class="flex flex-wrap gap-2 mt-1">
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">Streamlit</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">FastAPI</span>
                  <span class="px-3 py-1 bg-white border-2 border-black rounded-lg text-sm font-bold shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]">React.js</span>
                </div>
              </div>
            </div>
          </div>


        </div>
        </div>
      </div>
  </div>
</BaseLayout>